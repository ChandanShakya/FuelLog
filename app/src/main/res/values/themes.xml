<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FuelLog" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorPrimaryDark">@color/md_theme_light_primary</item>
        <item name="colorAccent">@color/md_theme_light_primary</item>
        <item name="android:windowBackground">@color/md_theme_light_background</item>
        <item name="android:textColorPrimary">@color/md_theme_light_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_light_onSurfaceVariant</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="Widget.FuelLog.Card" parent="">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>

    <style name="Widget.FuelLog.Badge" parent="">
        <item name="android:background">@drawable/bg_badge</item>
        <item name="android:paddingStart">@dimen/badge_padding_h</item>
        <item name="android:paddingEnd">@dimen/badge_padding_h</item>
        <item name="android:paddingTop">@dimen/badge_padding_v</item>
        <item name="android:paddingBottom">@dimen/badge_padding_v</item>
        <item name="android:textColor">@color/md_theme_light_onPrimaryContainer</item>
    </style>

</resources>
